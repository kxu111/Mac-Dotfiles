{
  "logo": {
    "type": "small",
    "source": "macos",

    "padding": {
      "top": 1,
    },
  },
  "display": {
    "separator": ": ",
  },
  "modules": [
    "break",
    "title",
    "separator",
    {
      "type": "os",
      "key": "OS  ",
      "keyColor": "red",
      "outputColor": "red",
    },
    {
      "type": "uptime",
      "key": "UPT ",
      "keyColor": "blue",
      "outputColor": "blue",
    },
    {
      "type": "cpu",
      "key": "CPU ",
      "format": "{name} @ {freq-max}",
      "keyColor": "yellow",
      "outputColor": "yellow",
    },
    {
      "type": "memory",
      "key": "RAM ",
      "format": "{used} / {total}",
      "keyColor": "blue",
      "outputColor": "blue",
    },
    {
      "type": "disk",
      "key": "DSK ",
      "format": "{size-used} / {size-total}",
      "keyColor": "yellow",
      "outputColor": "yellow",
    },
    "break",
    {
      "type": "colors",
      "symbol": "circle",
    },
  ],
}
