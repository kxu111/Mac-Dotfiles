{
  "logo": {
    "type": "small",
    "source": "macos",

    "padding": {
      "top": 1,
    },
  },
  "display": {
    "separator": ": ",
  },
  "modules": [
    "break",
	"title",
    {
      "type": "separator",
    },
    //  {
    //     "type": "os",
    //     "key": "OS  ",
    //     "keyColor": "blue",
    //     "outputColor": "blue",
    //   },
    {
      "type": "uptime",
      "key": "UPT ",
      "keyColor": "blue",
      "outputColor": "blue",
    },
    {
      "type": "wm",
      "key": "WM  ",
      "keyColor": "magenta",
      "outputColor": "magenta",
    },
    {
      "type": "cpu",
      "key": "CPU ",
      "format": "{name} @ {freq-max}",
      "keyColor": "blue",
      "outputColor": "blue",
    },

    {
      "type": "memory",
      "key": "RAM ",
      "format": "{used} / {total}",
      "keyColor": "magenta",
      "outputColor": "magenta",
    },
    {
      "type": "disk",
      "key": "DSK ",
      "format": "{size-used} / {size-total}",
      "keyColor": "blue",
      "outputColor": "blue",
    },
    "break",
    {
      "type": "colors",
      "symbol": "circle",
    },
  ],
}
